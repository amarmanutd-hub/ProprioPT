{
  "name": "proprio-portal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:workout": "WORKOUT_BASE=/workout/ npm --prefix ../pt-app run dev",
