VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
VITE_PORTAL_ORIGIN=http://localhost:5174

# Dashboard (required once):
# 1) SQL → run supabase/migrations/20260713165413_proprio_core_schema.sql
# 2) Auth → enable Anonymous sign-ins
# 3) Auth → Passkeys → enable + set RP ID (localhost for dev)
# 4) Auth → MFA → enable TOTP
# 5) Auth → URL config → redirect: http://localhost:5174/auth/callback
